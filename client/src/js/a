  const cancelModalBtn = document.getElementById("cancelModalBtn");
  const logoutMainBtn = document.getElementById("logoutButtonMain");

  if (!modal || !confirmBtn || !cancelBtn || !logoutMainBtn) return;

  // Hiện modal xác nhận khi bấm "Log out"
  logoutMainBtn.addEventListener("click", () => {
    modal.classList.remove("hidden");
  });

  // 👉 Xoá tài khoản
  confirmBtn.onclick = async () => {
    const user = auth.currentUser;
    if (!user) return;

    try {
      const providerId = user.providerData[0]?.providerId;

      if (providerId === "password") {
        const password = prompt("Nhập lại mật khẩu để xác nhận:");
        if (!password) {
          showToast("Bạn chưa nhập mật khẩu.", "error");
          return;
        }

        const credential = EmailAuthProvider.credential(user.email, password);
        await reauthenticateWithCredential(user, credential);

      } else if (providerId === "google.com") {
        const provider = new GoogleAuthProvider();
        await reauthenticateWithPopup(user, provider);
      } else {
        showToast("Không hỗ trợ kiểu đăng nhập này.", "error");
        return;
      }

      await deleteDoc(doc(db, "users", user.uid));
      await deleteUser(user);

      localStorage.removeItem("user_session");
      showToast("Tài khoản đã bị xóa hoàn toàn.", "success");
      window.location.href = "login.html";
    } catch (error) {
      console.error("Lỗi khi xoá:", error.message);
      if (error.code === "auth/popup-closed-by-user") {
        showToast("Bạn đã huỷ xác thực Google.", "info");
      } else if (error.code === "auth/wrong-password") {
        showToast("Mật khẩu không chính xác.", "error");
      } else {
        showToast("Không thể xoá tài khoản. Vui lòng thử lại.", "error");
      }
    }
  };

  // 👉 Đăng xuất
  cancelBtn.onclick = () => {
    modal.classList.add("hidden");
    signOut(auth)
      .then(() => {
        localStorage.removeItem("user_session");
        showToast("Đã đăng xuất thành công.", "success");
        window.location.href = "login.html";
      })
      .catch((error) => {
        console.error("Lỗi khi đăng xuất:", error.message);
        showToast("Lỗi khi đăng xuất.", "error");
      });
  };

  // 👉 Huỷ modal
  cancelModalBtn?.addEventListener("click", () => {
    modal.classList.add("hidden");
  });
}


const { Engine, Render, Runner, World, Bodies, Body, Events, Mouse, MouseConstraint, Vector } = Matter;

// Engine setup
const engine = Engine.create();
const world = engine.world;
world.gravity.y = 0;

// Canvas render setup
const render = Render.create({
  element: document.body,
  engine,
  options: {
    width: window.innerWidth,
    height: window.innerHeight,
    background: "transparent",
    wireframes: false,
    pixelRatio: Math.min(window.devicePixelRatio),
  },
});
Render.run(render);
Runner.run(Runner.create(), engine);

// Constants
const colors = ["#e63946", "#2a9d8f", "#f4a261", "#a8dadc", "#f77f00", "#3a86ff"];
const types = ["circle", "rectangle", "triangle"];
const shapeSize = 40; // ⬅ HÌNH TO HƠN
const shapes = [];

// Tránh form login
const wrapper = document.querySelector('.wrapper');
const wrapperRect = wrapper.getBoundingClientRect();
const wrapperBody = Bodies.rectangle(
  wrapperRect.left + wrapperRect.width / 2,
  wrapperRect.top + wrapperRect.height / 2,
  wrapperRect.width,
  wrapperRect.height,
  { isStatic: true, render: { visible: false } }
);
World.add(world, wrapperBody);

function isOverlappingLogin(x, y) {
  return (
    x > wrapperRect.left - 50 &&
    x < wrapperRect.right + 50 &&
    y > wrapperRect.top - 50 &&
    y < wrapperRect.bottom + 50
  );
}

// Tạo hình khối to, tự phản
for (let i = 0; i < 6; i++) {
  let x, y, attempts = 0;
  do {
    x = i < 5
      ? Math.random() * (window.innerWidth / 2 - 100)
      : Math.random() * (window.innerWidth / 2 - 100) + (window.innerWidth / 2 + 100);
    y = Math.random() * window.innerHeight;
    attempts++;
  } while (isOverlappingLogin(x, y) && attempts < 10);

  const type = types[Math.floor(Math.random() * types.length)];
  const color = colors[Math.floor(Math.random() * colors.length)];
  let shape;

  if (type === "circle") {
    shape = Bodies.circle(x, y, shapeSize / 2, {
      restitution: 0.6,
      render: { fillStyle: color },
      collisionFilter: { category: 0x0001 }, // ← Thêm dòng này
    });
  } else if (type === "rectangle") {
    shape = Bodies.rectangle(x, y, shapeSize, shapeSize, {
      restitution: 0.6,
      render: { fillStyle: color },
      collisionFilter: { category: 0x0001 }, // ← Thêm dòng này
    });
  } else {
    shape = Bodies.polygon(x, y, 3, shapeSize / 1.5, {
      restitution: 0.6,
      render: { fillStyle: color },
      collisionFilter: { category: 0x0001 }, // ← Thêm dòng này
    });
  }

  Body.setVelocity(shape, {
    x: (Math.random() - 0.5) * 2.5,
    y: (Math.random() - 0.5) * 2.5,
  });

  // Sau vài giây: làm đứng yên nhưng vẫn cho kéo
  shape.plugin = {
    frozen: false,
    active: true, // Để đảm bảo nó phản ứng va chạm từ đầu
    freezeTimeout: setTimeout(() => {
      Body.setVelocity(shape, { x: 0, y: 0 });
      Body.setAngularVelocity(shape, 0);
      shape.plugin.frozen = true;
      shape.plugin.active = false; // Tạm ngủ, chờ va chạm hoặc người kéo
    }, 6000 + Math.random() * 3000),
  };

  shapes.push(shape);
  World.add(world, shape);
}

// Va chạm tường để phản bật
const boundaries = [
  Bodies.rectangle(window.innerWidth / 2, -25, window.innerWidth, 50, { isStatic: true }),
  Bodies.rectangle(window.innerWidth / 2, window.innerHeight + 25, window.innerWidth, 50, { isStatic: true }),
  Bodies.rectangle(-25, window.innerHeight / 2, 50, window.innerHeight, { isStatic: true }),
  Bodies.rectangle(window.innerWidth + 25, window.innerHeight / 2, 50, window.innerHeight, { isStatic: true }),
];
World.add(world, boundaries);

// Mouse + tương tác kéo
const mouse = Mouse.create(render.canvas);
mouse.pixelRatio = window.devicePixelRatio;
mouse.offset = { x: 0, y: 0 }; // Nếu canvas cố định toàn màn hình

// Mouse constraint
const mouseConstraint = MouseConstraint.create(engine, {
  mouse,
  constraint: {
    stiffness: 0.3,
    render: { visible: false },
  },
});
mouseConstraint.collisionFilter.mask = 0x0001;
World.add(world, mouseConstraint);

// Canvas scale fix
render.canvas.width = window.innerWidth * window.devicePixelRatio;
render.canvas.height = window.innerHeight * window.devicePixelRatio;
render.canvas.style.touchAction = 'none';

// Khi người dùng kéo khối
Events.on(mouseConstraint, 'startdrag', (event) => {
  const shape = event.body;
  if (!shape || !shape.plugin) return;

  shape.plugin.frozen = false;
  shape.plugin.active = true;

  // Đẩy nhẹ để thoát trạng thái “ngủ”
  Body.setVelocity(shape, {
    x: (Math.random() - 0.5) * 4,
    y: (Math.random() - 0.5) * 4,
  });
});

// Cập nhật va chạm (nếu khối đã được bật lại → các khối khác va theo)
Events.on(engine, 'collisionStart', (event) => {
  const pairs = event.pairs;

  pairs.forEach(pair => {
    [pair.bodyA, pair.bodyB].forEach(body => {
      if (body.plugin && !body.plugin.active) {
        body.plugin.active = true;
        body.plugin.frozen = false;

        Body.setVelocity(body, {
          x: (Math.random() - 0.5) * 3,
          y: (Math.random() - 0.5) * 3,
        });
      }
    });
  });
});

render.canvas.addEventListener('mousemove', (e) => {
  const mousePosition = mouse.position;
  const found = Matter.Query.point(shapes, mousePosition);
  render.canvas.style.cursor = found.length > 0 ? 'grab' : 'default';
});

Events.on(mouseConstraint, 'startdrag', () => {
  render.canvas.style.cursor = 'grabbing';
});
Events.on(mouseConstraint, 'enddrag', () => {
  render.canvas.style.cursor = 'default';
});

