  const languages = ['en', 'vn'];
  langBtn.addEventListener('click', () => {
    const currentLang = localStorage.getItem("lang") || "en";
    const nextLang = languages[(languages.indexOf(currentLang) + 1) % languages.length];
    setLanguage(nextLang);
  });
}

